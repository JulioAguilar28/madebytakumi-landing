---
import Logo from "@/components/Logo.astro";
import { es } from "@/i18n/es";

const year = new Date().getFullYear();
const contactEmail = import.meta.env.PUBLIC_CONTACT_EMAIL ?? "hello@madebytakumi.com";
---

<footer class="border-t hairline py-10">
  <div class="container-shell grid gap-10 lg:grid-cols-[1fr_auto] lg:items-end">
    <div>
      <Logo />
      <p class="mt-6 text-lg font-medium" data-i18n="footer.tagline">{es.footer.tagline}</p>
      <p class="mt-2 text-sm text-muted" data-i18n="footer.statement">{es.footer.statement}</p>
    </div>
    <div class="grid gap-6 text-sm text-muted sm:flex sm:items-center">
      <a href="https://www.linkedin.com" target="_blank" rel="noreferrer" class="transition hover:text-accent" data-i18n="footer.linkedin">LinkedIn</a>
      <a href="https://github.com" target="_blank" rel="noreferrer" class="transition hover:text-accent" data-i18n="footer.github">GitHub</a>
      <a href={`mailto:${contactEmail}`} class="transition hover:text-accent" data-i18n="footer.email">Email</a>
      <span>© {year} <span data-i18n="footer.rights">{es.footer.rights}</span></span>
    </div>
  </div>
</footer>
