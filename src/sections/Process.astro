---
import SectionTitle from "@/components/SectionTitle.astro";
import { es } from "@/i18n/es";
---

<section id="process" class="container-shell py-24 sm:py-32">
  <div class="grid gap-10 lg:grid-cols-[0.85fr_1.15fr] lg:items-end">
    <SectionTitle eyebrowKey="process.eyebrow" titleKey="process.title" eyebrow={es.process.eyebrow} title={es.process.title} />
    <p class="reveal max-w-xl text-lg leading-8 text-muted lg:justify-self-end">
      <span data-i18n="process.intro">{es.process.intro}</span>
    </p>
  </div>

  <div class="reveal mt-16 overflow-hidden rounded-[2rem] border hairline bg-surface/70 p-5 shadow-[var(--shadow-soft)] sm:p-8 lg:p-10">
    <div class="mb-8 flex items-center justify-between gap-4 text-xs font-semibold uppercase tracking-[0.26em] text-muted">
      <span>Input</span>
      <span class="h-px flex-1 bg-line"></span>
      <span>Output</span>
    </div>

    <div class="relative">
      <div class="absolute left-7 top-0 h-full w-3 -translate-x-1/2 rounded-full bg-line lg:left-0 lg:top-8 lg:h-3 lg:w-full lg:translate-x-0"></div>
      <div class="absolute left-7 top-0 h-full w-3 -translate-x-1/2 rounded-full bg-gradient-to-b from-accent via-accent/55 to-foreground lg:left-0 lg:top-8 lg:h-3 lg:w-full lg:translate-x-0 lg:bg-gradient-to-r"></div>

      <div class="relative grid gap-5 lg:grid-cols-4">
        {es.process.steps.map(([title, description], index) => (
          <article class="group relative pl-20 lg:flex lg:min-h-[22rem] lg:flex-col lg:pl-0 lg:pt-20">
            <div class="absolute left-7 top-1/2 z-10 grid size-14 -translate-x-1/2 -translate-y-1/2 place-items-center rounded-full border-[6px] border-surface bg-foreground text-sm font-semibold text-background shadow-[0_16px_42px_rgba(11,11,11,0.16)] lg:left-1/2 lg:top-0 lg:translate-y-0">
              {String(index + 1).padStart(2, "0")}
            </div>
            <div class="flex h-full flex-col rounded-[1.5rem] border hairline bg-background p-6 transition duration-500 group-hover:-translate-y-1 group-hover:border-accent/60">
              <h3 class="text-2xl font-semibold tracking-[-0.04em]" data-i18n={`process.steps.${index}.0`}>{title}</h3>
              <p class="mt-4 text-sm leading-7 text-muted" data-i18n={`process.steps.${index}.1`}>{description}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>
