---
import { Languages } from "@lucide/astro";
---

<button
  type="button"
  class="inline-flex h-10 min-w-[4.75rem] items-center justify-center gap-2 rounded-full border hairline px-3 text-xs font-semibold tracking-[0.18em] transition duration-300 hover:border-accent hover:text-accent"
  data-lang-toggle
  data-i18n-aria="controls.language"
  aria-label="Cambiar idioma"
>
  <Languages class="size-3.5" stroke-width={1.8} aria-hidden="true" />
  <span data-lang-label>ES</span>
</button>
