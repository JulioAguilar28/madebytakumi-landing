---
import { ArrowUpRight, FileText } from "@lucide/astro";

interface Props {
  index: number;
  project: {
    title: string;
    description: string;
    keywords: readonly string[];
  };
}

const { index, project } = Astro.props;
const n = String(index + 1).padStart(2, "0");
---

<article class="reveal group rounded-[calc(var(--radius)*1.35)] border hairline bg-surface/70 p-6 shadow-[var(--shadow-soft)] transition duration-500 hover:-translate-y-1 hover:border-accent/50 sm:p-8">
  <div class="mb-10 flex items-start justify-between gap-6">
    <span class="font-mono text-xs tracking-[0.28em] text-muted">{n}</span>
    <span class="h-12 w-px origin-top bg-accent transition duration-500 group-hover:scale-y-125"></span>
  </div>
  <h3 class="text-2xl font-semibold tracking-[-0.03em]" data-i18n={`projects.items.${index}.title`}>{project.title}</h3>
  <p class="mt-4 min-h-16 text-base leading-7 text-muted" data-i18n={`projects.items.${index}.description`}>{project.description}</p>
  <div class="mt-8 flex flex-wrap gap-2">
    {project.keywords.map((keyword, keywordIndex) => (
      <span class="rounded-full border hairline px-3 py-1 text-xs text-muted" data-i18n={`projects.items.${index}.keywords.${keywordIndex}`}>
        {keyword}
      </span>
    ))}
  </div>
  <div class="mt-10 flex flex-wrap gap-4 text-sm font-medium">
    <a href="#contact" class="inline-flex items-center gap-1.5 text-foreground transition hover:text-accent">
      <span data-i18n="projects.view">Ver proyecto</span>
      <ArrowUpRight class="size-4" stroke-width={1.8} aria-hidden="true" />
    </a>
    <a href="#contact" class="inline-flex items-center gap-1.5 text-muted transition hover:text-accent">
      <span data-i18n="projects.study">Caso de estudio</span>
      <FileText class="size-4" stroke-width={1.8} aria-hidden="true" />
    </a>
  </div>
</article>
