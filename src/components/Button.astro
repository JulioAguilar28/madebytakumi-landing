---
import { ArrowRight, Eye } from "@lucide/astro";

interface Props {
  href: string;
  variant?: "primary" | "secondary";
  label?: string;
  keyName?: string;
  icon?: "arrow" | "eye";
}

const { href, variant = "primary", label, keyName, icon = variant === "primary" ? "arrow" : "eye" } = Astro.props;
const base =
  "group inline-flex min-h-12 items-center justify-center gap-2 rounded-full px-6 text-sm font-medium tracking-wide transition duration-300 focus-visible:outline-accent";
const styles =
  variant === "primary"
    ? "bg-foreground text-background hover:bg-accent hover:text-white"
    : "border hairline bg-background/40 text-foreground hover:border-accent hover:text-accent";
---

<a class={`${base} ${styles}`} href={href}>
  <span data-i18n={keyName}>{label}</span>
  {icon === "arrow" && <ArrowRight class="size-4 transition-transform duration-300 group-hover:translate-x-0.5" stroke-width={1.8} />}
  {icon === "eye" && <Eye class="size-4" stroke-width={1.8} />}
</a>
